# Copy this file to ".env" and fill in your key.
#   cp .env.example .env   (Windows PowerShell: Copy-Item .env.example .env)
# The .env file is git-ignored, so your secret never gets committed.

# OpenAI is the default backend for CrewAI (and for this case).
OPENAI_API_KEY=sk-...

# CrewAI cloud tracing (app.crewai.com). Off by default — MAADS writes local traces.
# Set MAADS_CREWAI_CLOUD_TRACING=1 to keep CREWAI_TRACING_ENABLED=true from .env.
# CREWAI_TRACING_ENABLED=false

# Which model the agents use.
#   - Local, free, offline (for development): MODEL=ollama/gemma2:9b
#       Requires a running Ollama server (https://ollama.com) with the model pulled:
#       ollama pull gemma2:9b   (or gemma2:2b if 9b is too slow on your GPU)
#       No OPENAI_API_KEY needed in this mode.
#   - Cloud (smarter, costs money): MODEL=gpt-4o-mini  (needs OPENAI_API_KEY above)
MODEL=ollama/gemma2:9b

# Per-agent model routing (optional). Each CrewAI Agent gets its own LLM instance.
# When MODEL starts with ollama/, use MODEL_JSON for structured JSON roles (pm, domain)
# and MODEL_CODE for Python authoring / DEBUG roles (developer, data_engineer,
# data_scientist). Unset tiers fall back to MODEL for backward compatibility.
# MODEL_JSON=ollama/gemma2:9b
MODEL_CODE=ollama/qwen2.5-coder:14b

# RAG embeddings for Domain Expert (CrewAI Knowledge + maads.rag retrieval).
# Local Ollama (default when MODEL=ollama/... and no OPENAI_API_KEY):
EMBEDDINGS_OLLAMA_MODEL_NAME=nomic-embed-text
# EMBEDDINGS_OLLAMA_URL=http://localhost:11434/api/embeddings
# EMBEDDINGS_PROVIDER=ollama   # force Ollama even if OPENAI_API_KEY is set
# Pull the model once: ollama pull nomic-embed-text
#
# Cloud alternative (unset EMBEDDINGS_PROVIDER=ollama):
# OPENAI_EMBED_MODEL=text-embedding-3-small
#
# Per-role override (highest priority), e.g.:
# MODEL_DEVELOPER=ollama/qwen2.5-coder:7b
# MODEL_DATA_ENGINEER=ollama/qwen2.5-coder:14b
#
# Cloud path: OPENAI_MODEL_TOP / OPENAI_MODEL_MID tier pm+data_scientist vs others;
# OPENAI_MODEL_CODE applies to developer, data_engineer, and data_scientist.
# OPENAI_MODEL_TOP=gpt-4o
# OPENAI_MODEL_MID=gpt-4o-mini
# OPENAI_MODEL_CODE=gpt-4o-mini

# Where the local Ollama server lives. Only used when MODEL starts with "ollama/".
# OLLAMA_BASE_URL=http://localhost:11434

# OLLAMA_REQUEST_TIMEOUT=600

# Cap total LLM tokens per `maads run` (CrewAI path; unset = no cap).
# MAX_TOKENS_PER_RUN=50000

# Optional: DeepSeek as an OpenAI-compatible, cheaper fallback (see project README).
# DEEPSEEK_API_KEY=

# Live stderr progress bar during `maads run` (on by default in a TTY).
# Set to 0 or pass --quiet to disable. CrewAI verbose stays off; this is the
# high-level CRISP-DM step + LLM activity line instead.
# MAADS_PROGRESS=1
#
# Agent–LLM communication capture (on by default when MAADS_TRACE=1):
#   full    — full prompts/responses in artifacts/<case>/trace/communications.*
#   preview — cap each text field at 2000 chars
#   off     — metadata only (no prompt/response bodies in sidecar markdown)
# MAADS_TRACE_LLM_IO=full
#
# File-based progress (always on): artifacts/<case>/runs/<run_id>/status.json
# update during the run — use these to monitor when stderr progress is hidden.
